# 2. Cloud Run Function → Dataflow (Flex Template)

**Architecture**

```text
GCS
   │
Eventarc
   │
Cloud Run Function
   │
Dataflow REST API
   │
Dataflow Job
   │
BigQuery
```

```python
import functions_framework
import requests
import google.auth
from google.auth.transport.requests import Request

PROJECT_ID = "gcp-free-trail-pavan-2026"
REGION = "us-central1"

DATAFLOW_URL = (
    f"https://dataflow.googleapis.com/v1b3/projects/"
    f"{PROJECT_ID}/locations/{REGION}/flexTemplates:launch"
)

@functions_framework.cloud_event
def trigger_dataflow(cloud_event):

    data = cloud_event.data

    bucket = data["bucket"]
    file_name = data["name"]

    if not file_name.endswith(".csv"):
        return

    payload = {
        "launchParameter": {
            "jobName": "employee-dataflow-job",
            "containerSpecGcsPath": "gs://niko-health/templates/dataflow-template.json",
            "parameters": {
                "inputFile": f"gs://{bucket}/{file_name}",
                "outputTable": "gcp-free-trail-pavan-2026:employee_niko_health.employee_1"
            }
        }
    }

    credentials, _ = google.auth.default()
    credentials.refresh(Request())

    headers = {
        "Authorization": f"Bearer {credentials.token}",
        "Content-Type": "application/json"
    }

    response = requests.post(
        DATAFLOW_URL,
        headers=headers,
        json=payload
    )

    response.raise_for_status()
```

