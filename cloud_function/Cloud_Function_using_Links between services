# 3. Cloud Run Function → Dataproc Serverless

**Architecture**

```text
GCS
   │
Eventarc
   │
Cloud Run Function
   │
Dataproc Batch API
   │
Dataproc Serverless
   │
BigQuery
```

```python
import functions_framework
import requests
import google.auth
from google.auth.transport.requests import Request

PROJECT_ID = "gcp-free-trail-pavan-2026"
REGION = "us-central1"

DATAPROC_URL = (
    f"https://dataproc.googleapis.com/v1/projects/"
    f"{PROJECT_ID}/locations/{REGION}/batches"
)

@functions_framework.cloud_event
def trigger_dataproc(cloud_event):

    data = cloud_event.data

    bucket = data["bucket"]
    file_name = data["name"]

    if not file_name.endswith(".csv"):
        return

    payload = {
        "pysparkBatch": {
            "mainPythonFileUri": "gs://niko-health/spark-code/Niko_Health_dataproc.py",
            "args": [
                bucket,
                file_name
            ]
        },
        "environmentConfig": {
            "executionConfig": {
                "serviceAccount": "niko-helath@gcp-free-trail-pavan-2026.iam.gserviceaccount.com"
            }
        }
    }

    credentials, _ = google.auth.default()
    credentials.refresh(Request())

    headers = {
        "Authorization": f"Bearer {credentials.token}",
        "Content-Type": "application/json"
    }

    response = requests.post(
        DATAPROC_URL,
        headers=headers,
        json=payload
    )

    response.raise_for_status()
```

